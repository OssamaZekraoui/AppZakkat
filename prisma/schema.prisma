// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zakatRecords ZakatRecord[]

  @@map("users")
}

model ZakatRecord {
  id        String   @id @default(cuid())
  userId    String
  year      Int
  goldValue Float    @default(0)
  silverValue Float  @default(0)
  cashValue Float    @default(0)
  stocksValue Float  @default(0)
  totalAssets Float  @default(0)
  nisabValue Float   @default(0)
  zakatAmount Float  @default(0)
  currency  String   @default("DZD")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("zakat_records")
}
